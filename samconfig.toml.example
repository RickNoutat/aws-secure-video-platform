# samconfig.toml — SAM CLI configuration
# This file is auto-generated by `sam deploy --guided`

version = 0.1

[default.deploy.parameters]
stack_name = "secure-video-platform-dev"
resolve_s3 = true
s3_prefix = "secure-video-platform"
region = "eu-west-1"
capabilities = "CAPABILITY_IAM CAPABILITY_AUTO_EXPAND"
confirm_changeset = true
image_repositories = []

[dev.deploy.parameters]
stack_name = "secure-video-platform-dev"
resolve_s3 = true
s3_prefix = "secure-video-platform-dev"
region = "eu-west-1"
capabilities = "CAPABILITY_IAM CAPABILITY_AUTO_EXPAND"

[prod.deploy.parameters]
stack_name = "secure-video-platform-prod"
resolve_s3 = true
s3_prefix = "secure-video-platform-prod"
region = "eu-west-1"
capabilities = "CAPABILITY_IAM CAPABILITY_AUTO_EXPAND"
confirm_changeset = true
